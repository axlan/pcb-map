#define R1_PIN 19
#define G1_PIN 5
#define B1_PIN 23
#define R2_PIN 25
#define G2_PIN 17
#define B2_PIN 26
#define A_PIN 27
#define B_PIN 16
#define C_PIN 14
#define D_PIN 4
#define E_PIN -1 // required for 1/32 scan panels, like 64x64px. Any available pin would do, i.e. IO32
#define LAT_PIN 15
#define OE_PIN 13
#define CLK_PIN 12

